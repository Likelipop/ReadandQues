# Django Settings Mode
DJANGO_SETTINGS_MODULE=ReadAndQues.settings_prod

# Production Security
SECRET_KEY=replace-with-a-random-secure-secret-key-for-production
DEBUG=0
ALLOWED_HOSTS=yourdomain.com,your-droplet-ip,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,http://your-droplet-ip

# PostgreSQL Database Configuration
DB_ENGINE=postgresql
DB_NAME=readandques
DB_USER=myuser
DB_PASSWORD=mypassword
DB_HOST=postgres
DB_PORT=5432

# MongoDB Configuration
MONGO_URI=mongodb://admin:changeme@mongo:27017/articlesDB?authSource=admin
MONGO_DB_NAME=articlesDB

# Chroma Vector Database
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Crawler Article Limits
ARTICLE_MIN_WORDS=500
ARTICLE_MAX_WORDS=4000
ARTICLE_MAX_IMAGES=10
