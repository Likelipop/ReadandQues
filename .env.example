# Django Settings Mode
DJANGO_SETTINGS_MODULE=ReadAndQues.settings_prod

# Production Security
SECRET_KEY=replace-with-a-random-secure-secret-key-for-production
DEBUG=0
ALLOWED_HOSTS=readques.app,www.readques.app,droplet ip,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://readques.app,https://www.readques.app,http://droplet ip

# PostgreSQL Database Configuration
DB_ENGINE=postgresql
DB_NAME=readandques
DB_USER=myuser
DB_PASSWORD=mypassword
DB_HOST=postgres
DB_PORT=5432

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_INITDB_DATABASE=articlesDB

# MongoDB Connection URI (Format: mongodb://<user>:<password>@<host>:<port>/<dbname>?authSource=admin)
# - Running in Docker (Production): host is 'mongo'
# - Running locally on host machine: host is 'localhost'
MONGO_URI=mongodb://admin:changeme@mongo:27017/articlesDB?authSource=admin
MONGO_DB_NAME=articlesDB



# Chroma Vector Database
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Azure OpenAI Configuration (AI Engine)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.services.ai.azure.com/
AZURE_DEPLOYMENT_NAME=gpt-5-mini

# SMTP Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Crawler Article Limits
ARTICLE_MIN_WORDS=500
ARTICLE_MAX_WORDS=4000
ARTICLE_MAX_IMAGES=10
